APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Indian Standard Time (IST, UTC+5:30) for wallet, calls, and logs
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Sign-In (Android/iOS) – Web client ID for ID token verification
# GOOGLE_CLIENT_ID=412016459555-unare7ejevmd28759nn3umseml8kovp2.apps.googleusercontent.com

# FCM – use HTTP v1 (service account). Legacy server key is optional (often disabled in Firebase).
# FCM_SERVER_KEY=   # Only if Legacy API is enabled in Firebase Console

# Firebase (kreait/laravel-firebase) – FCM for incoming call + new message.
# FIREBASE_CREDENTIALS=path/to/service-account.json (relative to project root, or absolute)
# Or use FCM_V1_CREDENTIALS_JSON=chataura-e67e6-firebase-adminsdk-fbsvc-6eac018db6.json
# FIREBASE_PROJECT_ID=chataura-e67e6   ← required so "Unable to determine the Firebase Project ID" is avoided
# FIREBASE_PROJECT=app

# Razorpay – wallet recharge
# RAZORPAY_KEY_ID=rzp_test_xxxx
# RAZORPAY_KEY_SECRET=xxxx

# Admin dashboard (password-protected /admin)
ADMIN_EMAIL=admin@chataura.com
ADMIN_PASSWORD=changeme
# Optional: set ADMIN_PASSWORD_HASH (bcrypt) to use hashed password instead of plain ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=

# Platform wallet for call commission (three-way transfer). User ID that holds admin share.
SYSTEM_USER_ID=1
